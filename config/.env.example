# ===========================================
# HERMES ↔ OPENCLAW BRIDGE CONFIGURATION
# ===========================================
# Copiar este archivo a .env y completar con datos reales
# NUNCA commitear .env a Git - usar .env.example como plantilla

# ===========================================
# BRIDGE DIRECTORIES
# ===========================================
BRIDGE_DIR=$HOME/.hermes-openclaw-bridge

# ===========================================
# TELEGRAM BOT CONFIGURATION (Kira)
# ===========================================
# 1. Crear bot con @BotFather en Telegram
# 2. Copiar el token aquí (formato: 123456789:ABCdefGhIjKlMnOpQRsTuVwXyZ)
KIRA_TELEGRAM_TOKEN=TU_BOT_TOKEN_AQUI

# 3. Obtener tu Chat ID:
#    - Enviar mensaje al bot
#    - Abrir: https://api.telegram.org/bot<TOKEN>/getUpdates
#    - Buscar "chat": {"id": 123456789}
KIRA_CHAT_ID=TU_CHAT_ID_AQUI

# ===========================================
# HERMES AGENT CONFIGURATION
# ===========================================
# Nombre del agente Hermes
HERMES_AGENT_NAME=kira

# Modelo LLM a usar (OpenRouter, Ollama, etc.)
HERMES_MODEL=kimi-k2.6:cloud

# Provider: openrouter, ollama, openai, etc.
HERMES_PROVIDER=openrouter

# API Key para el provider
HERMES_API_KEY=TU_API_KEY_AQUI

# ===========================================
# OPENCLAW AGENT CONFIGURATION
# ===========================================
# Nombre del agente OpenClaw que coordina
OPENCLAW_AGENT_NAME=aki

# Chat ID del usuario principal
OPENCLAW_USER_ID=TU_CHAT_ID_AQUI

# ===========================================
# SYSTEM CONFIGURATION
# ===========================================
# Timeout para comandos (segundos)
CMD_TIMEOUT=300

# Máximo tamaño de payload (bytes)
MAX_PAYLOAD_SIZE=10485760

# Retención de logs (días)
LOG_RETENTION_DAYS=30

# ===========================================
# OPTIONAL FEATURES
# ===========================================
# Habilitar logs detallados
VERBOSE_LOGGING=true

# Habilitar monitoreo de métricas
ENABLE_METRICS=true

# Habilitar limpieza automática de archivos antiguos
AUTO_CLEANUP=true
